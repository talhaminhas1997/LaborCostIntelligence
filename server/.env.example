# Copy to server/.env and add your key.
# The app runs fully WITHOUT a key — every endpoint has a deterministic
# fallback and Margin Watch runs entirely on seeded data. A real key turns on
# genuine Claude reasoning for chat, takeoff extraction, and bid analysis.
ANTHROPIC_API_KEY=sk-ant-...

# Optional — API port (defaults to 8787; the client dev proxy expects 8787).
# Use API_PORT, not PORT — dev runners/hosts inject PORT and would move the API
# off the port the Vite proxy targets.
# API_PORT=8787
